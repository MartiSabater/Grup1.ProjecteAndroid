<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_assistent_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/assistent_title"
        android:textColor="@color/shop_text_cyan"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_assistent_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/assistent_subtitle"
        android:textColor="@color/label_gray"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/et_assistent_question"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/rounded_input"
        android:gravity="top"
        android:hint="@string/assistent_question_hint"
        android:inputType="textMultiLine"
        android:padding="14dp"
        android:textColor="@color/white"
        android:textColorHint="@color/label_gray"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btn_assistent_ask"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/shop_button_buy"
        android:text="@string/assistent_ask"
        android:textColor="@color/black"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:background="@drawable/terminal_box"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_assistent_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/assistent_empty_answer"
            android:textColor="@color/terminal_green"
            android:textSize="15sp" />

    </ScrollView>

    <Button
        android:id="@+id/btn_assistent_back"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/shop_button_exit"
        android:text="@string/volver"
        android:textColor="@color/white"
        android:textStyle="bold" />

</LinearLayout>
