<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <View
            android:id="@+id/green_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_green"
            app:layout_constraintTop_toTopOf="@id/tv_system_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_system_title"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_system_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/terminal_title"
            android:textColor="@color/terminal_green"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/green_dot"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_academic_terminal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/academic_terminal"
            android:textColor="@color/cyan_accent"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_system_title" />

        <TextView
            android:id="@+id/tv_protocolo_sigma"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/protocolo_sigma"
            android:textColor="@color/white"
            android:textSize="48sp"
            android:textStyle="bold"
            android:lineSpacingExtra="-8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_academic_terminal" />

        <TextView
            android:id="@+id/tv_restricted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/restricted_access"
            android:textColor="@color/label_gray"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_protocolo_sigma" />

        <LinearLayout
            android:id="@+id/terminal_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/terminal_box"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_restricted">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/init_auth"
                android:textColor="@color/terminal_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/validating_creds"
                android:textColor="@color/terminal_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/currency_detected"
                android:textColor="@color/terminal_green" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/auth_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/terminal_container">

            <Button
                android:id="@+id/btn_login_tab"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/button_cyan_gradient"
                android:text="@string/login"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_registro_tab"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline"
                android:text="@string/registro"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_usuario_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/usuario"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/auth_buttons" />

        <EditText
            android:id="@+id/et_usuario"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_input"
            android:hint="@string/username_hint"
            android:paddingStart="16dp"
                android:paddingEnd="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/label_gray"
            app:layout_constraintTop_toBottomOf="@id/tv_usuario_label" />

        <TextView
            android:id="@+id/tv_password_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/password"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_usuario" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_input"
            android:hint="@string/password_hint"
            android:inputType="textPassword"
            android:paddingStart="16dp"
                android:paddingEnd="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/label_gray"
            app:layout_constraintTop_toBottomOf="@id/tv_password_label" />

        <Button
            android:id="@+id/btn_entrar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/button_cyan_gradient"
            android:text="@string/entrar_sistema"
            android:textColor="@color/black"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/et_password" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/terminal_box"
            android:padding="12dp"
            android:text="@string/account_created"
            android:textColor="@color/terminal_green"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/btn_entrar" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>