<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/shop_card_bg"
    android:padding="12dp">

    <ImageView
        android:id="@+id/iv_avatar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/terminal_box"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="@string/avatar_desc"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_player_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="[nom del Jugador]"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tv_player_points"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_avatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tv_player_points_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/puntos_label"
        android:textColor="@color/label_gray"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/tv_player_name"
        app:layout_constraintTop_toBottomOf="@id/tv_player_name" />

    <TextView
        android:id="@+id/tv_player_points"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:text="[Punts del Jugador]"
        android:textColor="@color/terminal_green"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tv_player_points_label"
        app:layout_constraintStart_toEndOf="@id/tv_player_points_label"
        app:layout_constraintTop_toTopOf="@id/tv_player_points_label" />

</androidx.constraintlayout.widget.ConstraintLayout>